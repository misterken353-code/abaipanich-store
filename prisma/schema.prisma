generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ADMIN (single-tenant — ร้านเดียว ไม่มี organizationId)
// ============================================================

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ============================================================
// SYNC — cache สต็อก/รูปที่ดึงมาจาก GearGao-SaaS (read-only)
// ============================================================

model SyncedProduct {
  id            String   @id @default(cuid())
  sourceId      String   @unique // Product.id ฝั่ง GearGao
  code          String
  name          String
  description   String?
  categoryName  String?
  unitName      String?
  salePrice     Decimal  @default(0)
  image1Url     String?
  image2Url     String?
  image3Url     String?
  image4Url     String?
  availableQty  Int      @default(0)
  isPreOrder    Boolean  @default(false)
  lastSyncedAt  DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  salePageItems SalePageItem[]
  orderItems    OrderItem[]

  @@index([code])
}

// ============================================================
// SALE PAGE — เพจขายที่แอดมินคัดสินค้ามาจัด
// ============================================================

model SalePage {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?
  coverUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items         SalePageItem[]
  facebookPosts FacebookPost[]
  orders        Order[]
}

model SalePageItem {
  id             String   @id @default(cuid())
  salePageId     String
  salePage       SalePage @relation(fields: [salePageId], references: [id], onDelete: Cascade)
  productId      String
  product        SyncedProduct @relation(fields: [productId], references: [id])
  sortOrder      Int      @default(0)
  priceOverride  Decimal?
  caption        String?
  createdAt      DateTime @default(now())

  @@unique([salePageId, productId])
}

// ============================================================
// ลูกค้า / ออเดอร์
// ============================================================

model Customer {
  id         String   @id @default(cuid())
  name       String
  phone      String
  address    String?
  lineUserId String?
  createdAt  DateTime @default(now())

  orders Order[]

  @@index([phone])
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  SHIPPED
  CANCELLED
}

// ขั้นการจัดส่งที่ลูกค้าเห็นในหน้าติดตามออเดอร์ (แยกจาก status ที่เกี่ยวกับการชำระเงิน)
// null = สั่งซื้อสำเร็จ รอร้านรับออเดอร์
enum DeliveryStage {
  RECEIVED   // ร้านรับออเดอร์แล้ว (ตั้งอัตโนมัติเมื่อแอดมินกด "รับออเดอร์")
  PREPARING  // กำลังจัดเตรียมสินค้า
  DELIVERING // กำลังจัดส่ง / พร้อมให้มารับ
  DELIVERED  // จัดส่งสำเร็จ (ตั้งอัตโนมัติเมื่อคนขับกด "จัดส่งสำเร็จ")
}

enum ShippingMethod {
  PICKUP      // รับเองหน้าร้าน
  MOTORCYCLE  // เรียกม้าเร็วจัดส่ง — ค่าส่งจ่ายแยกให้คนขับ ไม่รวมใน totalAmount/QR
  FREIGHT     // จัดส่งทางขนส่ง — ค่าส่งจ่ายปลายทาง ไม่รวมใน totalAmount/QR
}

enum PaymentMethod {
  COD      // จ่ายตอนรับของ — ไม่ generate QR, แจ้งร้านว่าเป็นเงินสดปลายทาง
  TRANSFER // โอนเงินผ่าน PromptPay — generate QR, เตือนลูกค้าส่งสลิปหลังโอน
}

model Order {
  id              String         @id @default(cuid())
  orderNo         String         @unique
  customerId      String
  customer        Customer       @relation(fields: [customerId], references: [id])
  salePageId      String?
  salePage        SalePage?      @relation(fields: [salePageId], references: [id])
  status          OrderStatus    @default(PENDING_PAYMENT)
  deliveryStage   DeliveryStage? // ขั้นการจัดส่งที่ลูกค้าติดตามได้ (null = รอร้านรับออเดอร์)
  totalAmount     Decimal
  shippingMethod  ShippingMethod @default(PICKUP)
  shippingAddress String?
  customerLat     Float?
  customerLng     Float?
  paymentMethod   PaymentMethod  @default(TRANSFER)
  note            String?
  promptPayQr     String?        @db.Text
  slipUrl         String?
  acknowledgedAt  DateTime?
  riderId         String?
  rider           Rider?         @relation(fields: [riderId], references: [id])
  assignedAt      DateTime?
  riderRating     Int?
  riderRatingComment String?
  riderCommission    Decimal?
  commissionSettled  Boolean    @default(false)
  settledAt          DateTime?
  deliveryFee     Decimal?       @default(0) // คำนวณจากระยะทางจริงตอนสร้างออเดอร์ (MOTORCYCLE เท่านั้น) — ยังจ่ายแยกให้คนขับเหมือนเดิม ไม่รวมใน totalAmount/QR
  codRemitted     Boolean        @default(false) // true = คนขับนำเงินสดค่าสินค้า (COD) มาคืนร้านแล้ว
  codRemittedAt   DateTime?
  hasPreOrder     Boolean        @default(false) // true ถ้ามีรายการ Pre-order อย่างน้อย 1 ชิ้น ณ ตอนสั่งซื้อ
  stockArrivedAt  DateTime?      // แอดมินกด "สินค้ามาถึงร้านแล้ว" — ต้องตั้งค่านี้ก่อนออเดอร์ Pre-order ถึงจะเข้าคิวส่งของปกติได้
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  items          OrderItem[]
  lineMessageLogs LineMessageLog[]
}

// ============================================================
// คนขับม้าเร็ว (ทำเนียบคนขับ — คนขับกดรับงานเองผ่านลิงก์เฉพาะตัว, แจ้งงานผ่าน LINE push)
// ============================================================

model Rider {
  id                    String   @id @default(cuid())
  name                  String
  phone                 String
  lineUserId            String?
  accessToken           String   @unique @default(cuid())
  isActive              Boolean  @default(true)
  isOnline              Boolean  @default(false) // คนขับกด "สแตนบายรับงาน" (ออนไลน์) — ปิดเมื่อพักรับงาน
  lastSeenAt            DateTime? // heartbeat: อัปเดตทุกครั้งที่หน้าคนขับ poll — ใช้ตัดคนที่ปิดแอปทิ้งไว้ออกจาก "พร้อมรับงาน"
  commissionPerDelivery Decimal  @default(0) // ค่าคอมมิชชั่นต่องาน (บาท) — แอดมินตั้งเอง default 0
  lastLat               Float?
  lastLng               Float?
  lastLocationAt        DateTime?
  createdAt             DateTime @default(now())

  orders Order[]
}

// ใบสมัครม้าเร็ว — คนทั่วไปสมัครผ่านหน้า /apply-rider (แนบรูปบัตรประชาชน)
// แอดมินอนุมัติแล้วระบบสร้าง Rider ให้อัตโนมัติ คุยงานต่อทาง LINE OA
enum RiderApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

model RiderApplication {
  id          String                 @id @default(cuid())
  name        String
  phone       String
  idCardImage String                 @db.Text // data URL (JPEG base64 บีบอัดฝั่ง client) — ยังไม่มี Blob storage
  note        String?
  status      RiderApplicationStatus @default(PENDING)
  riderId     String? // Rider ที่สร้างขึ้นตอนอนุมัติ
  reviewedAt  DateTime?
  createdAt   DateTime               @default(now())

  @@index([status])
  @@index([phone])
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId  String
  product    SyncedProduct @relation(fields: [productId], references: [id])
  nameSnapshot String
  priceSnapshot Decimal
  quantity   Int
  isPreOrder Boolean  @default(false) // snapshot จาก SyncedProduct.isPreOrder ตอนสั่งซื้อ
  arrivedAt  DateTime? // แอดมินยืนยันว่าซื้อของชิ้นนี้เข้าร้านแล้ว (ต่อรายการ ไม่ใช่ต่อออเดอร์)
}

// ============================================================
// FACEBOOK AUTO-POST (Phase 6)
// ============================================================

model FacebookPost {
  id         String   @id @default(cuid())
  salePageId String
  salePage   SalePage @relation(fields: [salePageId], references: [id], onDelete: Cascade)
  pageId     String
  postId     String?
  permalink  String?
  status     String   @default("PENDING") // PENDING | POSTED | FAILED
  error      String?
  createdAt  DateTime @default(now())
}

// ============================================================
// LINE OA MESSAGING API (Phase 7)
// ============================================================

model LineMessageLog {
  id         String   @id @default(cuid())
  orderId    String?
  order      Order?   @relation(fields: [orderId], references: [id])
  lineUserId String
  direction  String   // IN | OUT
  message    String   @db.Text
  createdAt  DateTime @default(now())

  @@index([lineUserId])
}

// ============================================================
// SETTINGS (singleton row)
// ============================================================

model AppSettings {
  id                     String  @id @default("singleton")
  promptPayId            String?
  facebookPageId         String?
  facebookPageAccessToken String? @db.Text
  lineChannelSecret      String? @db.Text
  lineChannelAccessToken String? @db.Text
  lineShopUserId         String? // userId ของแอดมิน/กลุ่มร้าน ที่จะ push แจ้งออเดอร์ใหม่/โลเคชั่นเข้าไป
  lineOaUrl              String? // ลิงก์เพิ่มเพื่อน LINE OA (เช่น https://lin.ee/xxxx) — ใช้ในหน้าสมัครม้าเร็ว
  storeLat               Float?  // พิกัดร้าน ใช้คำนวณค่าส่งม้าเร็วตามระยะทางจริง
  storeLng               Float?
  updatedAt              DateTime @updatedAt
}
